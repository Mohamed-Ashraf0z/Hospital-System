  <diagram id="uedDBjp-Z_iSIwonFi2j" name="Page-1">
    <mxGraphModel dx="4482" dy="3754" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="2336" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle Hospital Management System\n\n&#39; --- Primary Data Tables ---\nentity \&quot;users\&quot; as user {\n    * id : BIGINT &lt;&lt;PK&gt;&gt;\n    --\n    username : VARCHAR(255)\n    password : VARCHAR(255)\n    email : VARCHAR(255)\n    phone : VARCHAR(255) {Encrypted}\n    role : VARCHAR(50)\n    auth_verified : BOOLEAN\n    is_frozen : BOOLEAN\n}\n\nentity \&quot;user_permissions\&quot; as perm {\n    * user_id : BIGINT &lt;&lt;FK&gt;&gt;\n    * permission : VARCHAR(255)\n}\n\nentity \&quot;patients\&quot; as patient {\n    * id : BIGINT &lt;&lt;PK, FK&gt;&gt;\n    --\n    history_id : BIGINT &lt;&lt;FK&gt;&gt;\n}\n\nentity \&quot;doctors\&quot; as doctor {\n    * id : BIGINT &lt;&lt;PK, FK&gt;&gt;\n    --\n    specialization : VARCHAR(255)\n    rating : FLOAT\n    bio : TEXT\n}\n\nentity \&quot;doctor_certificates\&quot; as cert {\n    * doctor_id : BIGINT &lt;&lt;FK&gt;&gt;\n    * certificate_url : VARCHAR(500)\n}\n\n&#39; --- Clinical &amp; History Data ---\nentity \&quot;history_d\&quot; as history {\n    * id : BIGINT &lt;&lt;PK&gt;&gt;\n    --\n    patient_id : BIGINT &lt;&lt;FK&gt;&gt;\n    history_text : TEXT\n    note : TEXT\n}\n\nentity \&quot;appointed_patients\&quot; as appointed {\n    * id : BIGINT &lt;&lt;PK&gt;&gt;\n    --\n    doctor_id : BIGINT &lt;&lt;FK&gt;&gt;\n    patient_user_id : BIGINT &lt;&lt;FK&gt;&gt;\n    patient_name : VARCHAR(255)\n}\n\n&#39; --- Scheduling ---\nentity \&quot;availability_slots\&quot; as slot {\n    * id : BIGINT &lt;&lt;PK&gt;&gt;\n    --\n    doctor_id : BIGINT &lt;&lt;FK&gt;&gt;\n    start_time : TIME\n    end_time : TIME\n    duration_minutes : INT\n}\n\nentity \&quot;slot_days\&quot; as slot_day {\n    * slot_id : BIGINT &lt;&lt;FK&gt;&gt;\n    * day_name : VARCHAR(20)\n}\n\nentity \&quot;appointments\&quot; as appt {\n    * id : BIGINT &lt;&lt;PK&gt;&gt;\n    --\n    availability_slot_id : BIGINT &lt;&lt;FK&gt;&gt;\n    patient_id : BIGINT &lt;&lt;FK&gt;&gt;\n    doctor_id : BIGINT &lt;&lt;FK&gt;&gt;\n    note : TEXT\n    patient_name : VARCHAR(255)\n    doctor_name : VARCHAR(255)\n    date : DATE\n    time_slot : VARCHAR(50)\n}\n\n&#39; --- Relationships ---\n\n&#39; Identity Links\nuser ||--o| patient : \&quot;identifies\&quot;\nuser ||--o| doctor : \&quot;identifies\&quot;\nuser ||--o{ perm : \&quot;has\&quot;\n\n&#39; Clinical Links\npatient ||--o| history : \&quot;owns\&quot;\ndoctor ||--o{ cert : \&quot;uploads\&quot;\ndoctor ||--o{ slot : \&quot;manages\&quot;\nslot ||--o{ slot_day : \&quot;occurs on\&quot;\n\n&#39; Operational Links\ndoctor ||--o{ appt : \&quot;attends\&quot;\npatient ||--o{ appt : \&quot;books\&quot;\nslot ||--o| appt : \&quot;is locked by\&quot;\ndoctor ||--o{ appointed : \&quot;manages queue\&quot;\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="OyADFi8Tq_fXoBviTkyV-115">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
