        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\ntitle Sequence Diagram: Make Appointment\nhide footbox\n\nactor Patient\nboundary \&quot;System\&quot; as UI\ncontrol \&quot;AppointmentService\&quot; as ApptSvc\ndatabase \&quot;Database\&quot; as DB\nactor Doctor\n\nPatient -&gt; UI : Select Doctor &amp; Slot\nUI -&gt; ApptSvc : makeAppointment(slotId)\n\nApptSvc -&gt; DB : findSlotById(slotId)\nDB --&gt; ApptSvc : Slot Object\n\nalt Slot is Available\n    ApptSvc -&gt; DB : lockSlot(slotId)\n    ApptSvc -&gt; DB : saveAppointment(patientId, doctorId, slotId)\n    DB --&gt; ApptSvc : Appointment Created\n    ApptSvc --&gt; UI : Success Confirmation\n    \n    &#39; The appointment is simply added to the DB, no push notification\n    Doctor -&gt; UI : Refresh \&quot;Appointed Patients\&quot; Queue\n    UI -&gt; DB : Fetch current appointments\n    DB --&gt; UI : List of patients\n    UI --&gt; Doctor : Display active queue\nelse Slot is Taken\n    ApptSvc --&gt; UI : Error: Slot Unavailable\nend\n\nUI --&gt; Patient : Display Result\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="dL9DpMprYrqVfI2_PSuW-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
